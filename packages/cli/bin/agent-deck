#!/usr/bin/env bash
# Dev fallback when invoked from packages/cli/bin (repo). Published npm uses dist/bin.js directly.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PKG_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
if [[ -f "$PKG_ROOT/dist/bin.js" ]]; then
  exec node "$PKG_ROOT/dist/bin.js" "$@"
fi
exec npx tsx "$PKG_ROOT/src/bin.ts" "$@"
