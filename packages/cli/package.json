{
  "name": "@agent-deck/cli",
  "version": "1.2.4",
  "description": "Local MCP proxy with decks — one endpoint for Claude Code, Cursor, and other MCP clients",
  "license": "ISC",
  "bin": {
    "agent-deck": "./dist/bin.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "mcpName": "io.github.not-so-fat/agent-deck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/not-so-fat/agent_deck.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "claude",
    "cursor",
    "deck"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/pre-publish-check.mjs && npm run build"
  },
  "dependencies": {
    "@agent-deck/backend": "^1.2.4",
    "@agent-deck/shared": "^1.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
