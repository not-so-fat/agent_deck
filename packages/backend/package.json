{
  "name": "@agent-deck/backend",
  "version": "1.4.0",
  "description": "Agent Deck backend API, MCP server, and vault",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli-runtime": {
      "types": "./dist/cli-runtime.d.ts",
      "default": "./dist/cli-runtime.js"
    },
    "./mcp": {
      "types": "./dist/mcp-index.d.ts",
      "default": "./dist/mcp-index.js"
    }
  },
  "files": [
    "dist",
    "static-ui",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node --max-old-space-size=8192 ../../node_modules/typescript/bin/tsc",
    "dev": "AGENT_DECK_DEV=1 tsx watch src/index.ts",
    "mcp": "AGENT_DECK_DEV=1 tsx src/mcp-index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist static-ui",
    "type-check": "node --max-old-space-size=8192 ../../node_modules/typescript/bin/tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepublishOnly": "node ../../scripts/pre-publish-check.mjs && npm run build"
  },
  "dependencies": {
    "@agent-deck/shared": "^1.4.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.1",
    "express": "^4.19.2",
    "fastify": "^5.0.0",
    "openid-client": "^6.6.4",
    "use-mcp": "^0.0.21",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
