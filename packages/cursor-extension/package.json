{
  "name": "agent-deck-cursor",
  "displayName": "Agent Deck",
  "description": "Show the bound Agent Deck in the Cursor/VS Code status bar while you use Agent chat",
  "version": "0.1.0",
  "publisher": "agent-deck",
  "private": true,
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/not-so-fat/agent_deck.git",
    "directory": "packages/cursor-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentDeck.refreshDeckStatus",
        "title": "Agent Deck: Refresh Bound Deck Status"
      },
      {
        "command": "agentDeck.openDashboard",
        "title": "Agent Deck: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Agent Deck",
      "properties": {
        "agentDeck.backendHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Agent Deck API host"
        },
        "agentDeck.backendPorts": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "default": [
            8000,
            11111
          ],
          "description": "Ports to try for GET /api/scope/display (8000 = dev:all, 11111 = agent-deck start)"
        },
        "agentDeck.pollIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "How often to refresh the status bar"
        },
        "agentDeck.requestTimeoutMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "description": "API request timeout"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@agent-deck/shared": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
